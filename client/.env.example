# Copia este archivo como .env en la carpeta client/
# Nunca subas .env a GitHub

# URL del backend en producción (Render, Railway, Fly.io, etc.)
# Déjalo vacío en desarrollo local — Vite usa el proxy /api
VITE_API_URL=https://tu-api.onrender.com

# Base path para GitHub Pages: /nombre-del-repo/
# En dominio propio o local: /
VITE_BASE_PATH=/
