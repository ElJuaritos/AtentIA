# Copia este archivo como .env en la carpeta server/
# Nunca subas .env a GitHub

PORT=3001
NODE_ENV=production

# Orígenes permitidos para CORS (separados por coma)
# Incluye tu dominio de GitHub Pages y dominio personalizado
ALLOWED_ORIGINS=https://tu-usuario.github.io,https://mati.mx,http://localhost:5173

# Supabase — almacenamiento persistente de la waitlist
# Obtén estos valores en: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://gpfcccvahhhzodjrmuke.supabase.co
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY

# Google Sheets — ver server/scripts/google-apps-script.js (opcional)
# GOOGLE_SHEETS_SECRET debe ser idéntico a SHEET_SECRET del Apps Script
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/TU_ID/exec
GOOGLE_SHEETS_SECRET=AtentIA-Waitlist-2026-Kx9mP2vL8n
